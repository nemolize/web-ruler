{
  "name": "web-ruler",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev --turbo",
    "build": "NEXT_TELEMETRY_DISABLED=1 next build",
    "start": "next start",
    "lint": "run-p --continue-on-error 'lint:*'",
    "lint:eslint": "eslint .",
    "lint:typecheck": "tsc --noEmit",
